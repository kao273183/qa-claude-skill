{
  "$schema": "./config.schema.json",
  "$comment": "複製此檔為 config.json 後填入你的組織資訊。未填寫的欄位在 install.sh 執行時會警告。",

  "mode": "full-mcp",

  "jira": {
    "instance_url": "https://your-company.atlassian.net",
    "project_key": "PROJ",
    "bug_issue_type_id": "10046",
    "reviewer_account_id": "",
    "reviewer_field": "customfield_10045",
    "boards": [
      {
        "name": "Team-A",
        "board_id": "111",
        "team_id": "",
        "scope": "首頁相關"
      },
      {
        "name": "Team-B",
        "board_id": "222",
        "team_id": "",
        "scope": "IOM 相關"
      }
    ],
    "priority_mapping": {
      "Blocker": "Highest",
      "Critical": "High",
      "Major": "Medium",
      "Minor": "Low"
    }
  },

  "slack": {
    "user_id": "",
    "bug_channel_id": "",
    "release_channel_id": "",
    "notification_rules": {
      "bug_report": ["dm", "channel"],
      "tc_review_complete": ["dm"],
      "regression_published": ["channel"]
    }
  },

  "google": {
    "tc_template_id": "",
    "qa_tc_folder_id": "",
    "release_schedule_id": "",
    "regression_template_id": "",
    "outsource_bug_sheet_id": "",
    "default_drive": "shared",
    "$comment_default_drive": "shared | personal — 預設要把生成的 Sheet 放在共用雲端硬碟或我的雲端硬碟"
  },

  "platforms": {
    "ios": {
      "default_device": "iPhone 15 Pro",
      "default_os_version": "iOS 17.5",
      "min_os_version": "iOS 16.0",
      "repo": "your-org/your-ios-repo",
      "release_branch_pattern": "release/{version}",
      "version_file": "**/*.xcconfig"
    },
    "android": {
      "default_device": "Pixel 8",
      "default_os_version": "Android 14",
      "min_api_level": 28,
      "repo": "your-org/your-android-repo",
      "release_tag_pattern": "v{version}",
      "version_file": "**/build.gradle"
    },
    "flutter": {
      "enabled": false,
      "repo": "your-org/your-flutter-repo",
      "min_dart_sdk": "3.0.0"
    },
    "web": {
      "enabled": false,
      "repo": "your-org/your-web-repo",
      "default_browsers": ["chrome", "safari"],
      "$comment_default_browsers": "chrome | safari | firefox | edge — smoke 測試的預設瀏覽器組合",
      "supported_browsers": ["chrome", "safari", "firefox", "edge"],
      "min_browser_versions": {
        "chrome": "latest-2",
        "safari": "latest-1",
        "firefox": "latest-2",
        "edge": "latest-2"
      },
      "frameworks": {
        "primary": "playwright",
        "$comment_primary": "playwright | cypress | selenium | webdriverio — 主要 E2E 框架",
        "component_test": "playwright-component",
        "$comment_component_test": "playwright-component | cypress-component | none",
        "visual_regression": "playwright-snapshot",
        "$comment_visual_regression": "playwright-snapshot | percy | chromatic | none"
      },
      "viewport_sizes": {
        "desktop": "1920x1080",
        "tablet": "768x1024",
        "mobile": "375x667"
      },
      "base_url_envs": {
        "uat": "https://uat.example.com",
        "staging": "https://staging.example.com",
        "production": "https://example.com"
      }
    }
  },

  "test_case_format": {
    "columns": {
      "A": "ID",
      "B": "Phase",
      "C": "測試結果",
      "D": "測試結論",
      "E": "測試標題",
      "F": "測試分類",
      "G": "優先度",
      "H": "平台",
      "I": "前置條件",
      "J": "測試步驟",
      "K": "預期結果",
      "L": "自動化",
      "M": "備註",
      "N": "JIRA Ticket"
    },
    "categories": [
      "冒煙-Feature Done",
      "功能測試",
      "異常/邊界測試",
      "API 驗證測試",
      "內部狀態驗證"
    ],
    "priorities": ["P0", "P1", "P2"],
    "platforms": ["iOS", "Android", "Both"],
    "id_prefix": {
      "black_box": "BB",
      "white_box": "WB"
    }
  },

  "review_protocol": {
    "tri_party_enabled": false,
    "reviewers": ["claude", "codex", "gemini"],
    "dimensions": 10,
    "max_score_per_dimension": 5,
    "severity_thresholds": {
      "critical_max": 2.0,
      "major_max": 3.5,
      "minor_max": 4.5
    }
  },

  "backend": {
    "pytest_enabled": false,
    "pytest_project_root": "",
    "client_naming": "<feature>_client + <feature>_auth_client",
    "schema_dsl": "plain_dict",
    "$comment_schema_dsl": "plain_dict | s_dsl | pydantic — schema 定義方式",
    "feature_modules": [],
    "mutation": {
      "enabled": false,
      "score_target": 80,
      "critical_score_target": 95,
      "output_root": "~/.local/share/qa-mutation"
    },
    "property_based": {
      "enabled": false,
      "default_max_examples": 200,
      "ci_max_examples": 100,
      "thorough_max_examples": 1000
    }
  },

  "speckit": {
    "enabled": false,
    "repo_root": "",
    "feature_routing": [
      {
        "keywords": ["stamp", "NFC", "圖章"],
        "path": "love/stamp/",
        "epic": ""
      },
      {
        "keywords": ["health", "步數", "HealthKit"],
        "path": "peace/health/",
        "epic": ""
      }
    ],
    "fallback": "ask_user",
    "$comment_fallback": "ask_user | error — 沒 match 時的行為"
  },

  "publish_regression": {
    "enabled": false,
    "html_generator_script": "",
    "index_generator_script": "",
    "report_pipeline": {
      "type": "local_html",
      "$comment_type": "s3_cloudfront | local_html",
      "s3_bucket": "",
      "s3_region": "ap-northeast-1",
      "s3_prefix": "pytest-reports/",
      "cloudfront_distribution_id": "",
      "dashboard_url": "",
      "report_url_template": "http://{bucket}.s3-website-{region}.amazonaws.com/{prefix}manual-{env}-{version}/{timestamp}/report.html"
    },
    "default_env": "uat",
    "naming_pattern": "manual-{env}-{version}"
  },

  "smoke": {
    "time_budgets": { "T0": 3, "T1": 10, "T2": 60 },
    "$comment_time_budgets": "minutes — per-tier CI execution budget",
    "scoring_weights": {
      "criticality": 0.30,
      "speed": 0.25,
      "stability": 0.25,
      "independence": 0.10,
      "coverage_value": 0.10
    }
  },

  "performance": {
    "enabled": false,
    "primary_framework": "k6",
    "$comment_primary_framework": "k6 | locust | jmeter",
    "default_sla": {
      "p95_ms": 1000,
      "p99_ms": 3000,
      "error_rate_max": 0.01,
      "success_rate_min": 0.99
    },
    "base_url_uat": "",
    "base_url_staging": ""
  },

  "visual_regression": {
    "enabled": false,
    "tool": "playwright",
    "$comment_tool": "playwright | percy | chromatic | backstop",
    "max_diff_ratio": 0.02,
    "$comment_max_diff_ratio": "0.02 = 2% pixel tolerance",
    "mask_dynamic_elements": true,
    "auto_freeze_animations": true
  },

  "flaky_hunter": {
    "ci_platform": "",
    "$comment_ci_platform": "github-actions | gitlab-ci | circleci | jenkins | auto (default)",
    "lookback_days": 30,
    "flaky_threshold": 0.01,
    "$comment_flaky_threshold": "1% — 以上算 flaky",
    "high_flaky_threshold": 0.30,
    "auto_quarantine": false,
    "$comment_auto_quarantine": "建議 false，需手動同意才標 quarantine"
  },

  "contract_test": {
    "enabled": false,
    "primary_tool": "pact",
    "$comment_primary_tool": "pact | schemathesis | spring-cloud",
    "pact_broker_url": "",
    "relationships": []
  },

  "security_scan": {
    "enabled": false,
    "tools": ["semgrep", "snyk", "gitleaks"],
    "$comment_tools": "可選: semgrep snyk gitleaks bandit trivy zap",
    "severity_threshold": "high",
    "$comment_severity_threshold": "critical | high | medium | low — CI fail 門檻",
    "dast_target_url": "",
    "$comment_dast_target_url": "DAST 目標 URL — 必須是 staging/uat，絕不能是 production"
  },

  "a11y_audit": {
    "standard": "WCAG21AA",
    "$comment_standard": "WCAG21AA | WCAG22AA | Section508",
    "lighthouse_threshold": 90,
    "tools": ["axe", "lighthouse"]
  },

  "localization": {
    "supported_locales": ["en"],
    "base_locale": "en",
    "translation_files_pattern": "**/i18n/*.json",
    "rtl_locales": ["ar", "he", "fa", "ur"]
  },

  "push_notification": {
    "platforms": [],
    "$comment_platforms": "可選: ios android web — 空陣列表示不啟用此 skill",
    "test_devices": [],
    "deep_link_scheme": "",
    "payload_templates_dir": "tests/push/"
  },

  "test_data_factory": {
    "entities": [],
    "$comment_entities": "[ { name, fields: { fieldName: { type, min, max, ref } } } ]",
    "default_seed": null,
    "$comment_default_seed": "null = random，固定數字 = deterministic（重現 bug 用）",
    "email_domain": "example.com",
    "platforms": ["all"]
  },

  "language": {
    "primary": "zh-TW",
    "secondary": "en",
    "$comment": "primary 決定 Skill 主要輸出語言；secondary 是 README/docs 的對照語言"
  },

  "workflow": {
    "auto_cross_platform_check": true,
    "auto_a11y_pairing": true,
    "$comment_a11y": "a11y bug 自動開一對 iOS+Android 用 Relates 連結",
    "auto_root_cause_depth": {
      "ios": "deep",
      "android": "suggestion-only",
      "$comment": "deep = 深入程式碼分析；suggestion-only = 只給分析建議不深入碼"
    }
  }
}
