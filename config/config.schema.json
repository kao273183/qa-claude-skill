{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QA Claude Skill Config",
  "type": "object",
  "required": ["mode", "jira", "platforms"],
  "properties": {
    "mode": {
      "enum": ["full-mcp", "partial-mcp", "markdown-only"],
      "description": "整體運作模式 — 是否使用 MCP 工具"
    },
    "jira": {
      "type": "object",
      "required": ["instance_url", "project_key"],
      "properties": {
        "instance_url": { "type": "string", "format": "uri" },
        "project_key": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" },
        "bug_issue_type_id": { "type": "string" },
        "reviewer_account_id": { "type": "string" },
        "reviewer_field": { "type": "string", "pattern": "^customfield_\\d+$" },
        "boards": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "board_id"],
            "properties": {
              "name": { "type": "string" },
              "board_id": { "type": "string" },
              "team_id": { "type": "string" },
              "scope": { "type": "string" }
            }
          }
        },
        "priority_mapping": {
          "type": "object",
          "properties": {
            "Blocker": { "type": "string" },
            "Critical": { "type": "string" },
            "Major": { "type": "string" },
            "Minor": { "type": "string" }
          }
        }
      }
    },
    "slack": {
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "bug_channel_id": { "type": "string" },
        "release_channel_id": { "type": "string" },
        "notification_rules": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "enum": ["dm", "channel", "thread"] }
          }
        }
      }
    },
    "google": {
      "type": "object",
      "properties": {
        "tc_template_id": { "type": "string" },
        "qa_tc_folder_id": { "type": "string" },
        "release_schedule_id": { "type": "string" },
        "regression_template_id": { "type": "string" },
        "outsource_bug_sheet_id": { "type": "string" },
        "default_drive": { "enum": ["shared", "personal"] }
      }
    },
    "platforms": {
      "type": "object",
      "required": ["ios", "android"],
      "properties": {
        "ios": {
          "type": "object",
          "required": ["default_device", "default_os_version"],
          "properties": {
            "default_device": { "type": "string" },
            "default_os_version": { "type": "string" },
            "min_os_version": { "type": "string" },
            "repo": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
            "release_branch_pattern": { "type": "string" },
            "version_file": { "type": "string" }
          }
        },
        "android": {
          "type": "object",
          "required": ["default_device", "default_os_version"],
          "properties": {
            "default_device": { "type": "string" },
            "default_os_version": { "type": "string" },
            "min_api_level": { "type": "integer", "minimum": 21 },
            "repo": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
            "release_tag_pattern": { "type": "string" },
            "version_file": { "type": "string" }
          }
        },
        "flutter": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "repo": { "type": "string" },
            "min_dart_sdk": { "type": "string" }
          }
        }
      }
    },
    "test_case_format": { "type": "object" },
    "review_protocol": { "type": "object" },
    "language": {
      "type": "object",
      "properties": {
        "primary": { "enum": ["zh-TW", "zh-CN", "en", "ja"] },
        "secondary": { "type": "string" }
      }
    },
    "workflow": { "type": "object" }
  }
}
